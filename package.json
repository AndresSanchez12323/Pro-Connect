{
  "name": "parcial-proyecto-construccion-software",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "setup:local": "pnpm run install:all",
    "install:all": "pnpm -C pro-connect/backend install && pnpm -C pro-connect/frontend install",
    "db:up": "docker compose -f pro-connect/docker-compose.yml up -d",
    "db:down": "docker compose -f pro-connect/docker-compose.yml down",
    "start:dev": "concurrently \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
    "dev": "pnpm run dev:frontend",
    "dev:frontend": "pnpm -C pro-connect/frontend run dev",
    "dev:backend": "pnpm -C pro-connect/backend run start:dev",
    "seed": "pnpm -C pro-connect/backend run seed",
    "build": "pnpm run build:frontend && pnpm run build:backend",
    "build:frontend": "pnpm -C pro-connect/frontend run build",
    "build:backend": "pnpm -C pro-connect/backend run build"
  },
  "devDependencies": {
    "@types/multer": "^2.1.0",
    "concurrently": "^9.2.1"
  }
}
